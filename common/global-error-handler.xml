	<sub-flow name="prepare-error-response-subflow">
    
    <ee:transform doc:name="Map Error &amp; Status">
        <ee:message>
				<ee:set-payload resource="dwl/error-response.dwl" />
        
</ee:message>
        <ee:variables>
            <ee:set-variable variableName="httpStatus"><![CDATA[%dw 2.0
output application/java
---
if (error.errorType.identifier == "CONNECTIVITY") 504
else if (error.errorType.identifier == "UNAUTHORIZED") 401
else if (error.errorType.identifier == "BAD_REQUEST") 400
else if (error.errorType.identifier == "NOT_FOUND") 404
else 500]]></ee:set-variable>
        </ee:variables>
    </ee:transform>
		<set-variable value="#[output json --- payload.error.code default 500]" doc:name="httpStatus" doc:id="9d5d493e-0bf7-4467-acc4-c12c5e380b04" variableName="httpStatus" />
		<logger level="ERROR" doc:name="Logger ERROR" message='#[%dw 2.0&#10;output application/json&#10;---&#10;payload]' />

</sub-flow>
</mule>
